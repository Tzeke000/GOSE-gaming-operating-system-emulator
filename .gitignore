# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
!pc-image/dist/
.venv/
venv/

# Agent runtime
agent.token
*.log

# Secrets — dev token / .env. The per-install agent token is generated ON-DEVICE
# (first boot) and stored out-of-repo (/userdata/system/gose/token); never commit it.
.env
*.env
!.env.example
token

# Editor / tooling backup copies (may contain pre-fix secrets)
*.bak

# Claude Code local (machine-specific permissions)
.claude/settings.local.json

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# AI-generated brand media (heavy; gets wired into the OS deliberately, not committed raw)
docs/asset-prompts/generated/

# Large/binary device artifacts (don't commit OS images or ROMs)
*.img
*.iso
*.zip
*.7z
roms/

# Node (only used to vendor assets; never commit)
node_modules/
package-lock.json
