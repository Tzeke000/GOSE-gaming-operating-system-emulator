# GOSE agent token — TEMPLATE. Copy to ".env" (gitignored) for LOCAL DEV.
#
#   cp .env.example .env   &&   edit GOSE_AGENT_TOKEN below
#
# You do NOT need this on a real/shipped device: the agent token is GENERATED
# per-install on first boot (secrets.token_hex) and stored mode-600 at
# /userdata/system/gose/token. The agent AND the UI server read that same file,
# so every device has its OWN unique token and nothing secret lives in the repo.
#
# This .env only matters for a developer running/driving the dev VM. Put the dev
# VM's current token here (NEVER commit the real value — .env is gitignored):
GOSE_AGENT_TOKEN=changeme
